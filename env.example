import React, { useEffect, useState } from 'react';
import { supabase } from '../lib/supabase';
import { Employee, Schedule as ScheduleType } from '../types';
import { format, startOfMonth, endOfMonth, parseISO, eachDayOfInterval, isWeekend } from 'date-fns';
import { FileText, Download, Printer, ChevronDown, ChevronUp, FileSpreadsheet } from 'lucide-react';
import { formatMinutes } from '../lib/utils';
import { getKosovoHoliday } from '../lib/holidays';
import jsPDF from 'jspdf';
import autoTable from 'jspdf-autotable';
import { toast } from 'sonner';

const isApproved = (note: string | null) => {
  if (!note) return true;
  return !note.includes('STATUS:Pending') && !note.includes('STATUS:Rejected');
};

export function Reports() {
  const [employees, setEmployees] = useState<Employee[]>([]);
  const [schedules, setSchedules] = useState<ScheduleType[]>([]);
  const [loading, setLoading] = useState(true);
  const [selectedMonth, setSelectedMonth] = useState(format(new Date(), 'yyyy-MM'));
  const [expandedEmp, setExpandedEmp] = useState<string | null>(null);

  useEffect(() => {
    loadData();
  }, [selectedMonth]);

  async function loadData() {
    setLoading(true);
    
    // Parse selected month (e.g., "2023-10")
    const [year, month] = selectedMonth.split('-');
    const startDate = startOfMonth(new Date(parseInt(year), parseInt(month) - 1));
    const endDate = endOfMonth(new Date(parseInt(year), parseInt(month) - 1));
    
    const startDateStr = format(startDate, 'yyyy-MM-dd');
    const endDateStr = format(endDate, 'yyyy-MM-dd');

    const [empRes, schedRes] = await Promise.all([
      supabase.from('employees').select('*').order('first_name'),
      supabase.from('schedules').select('*').gte('date', startDateStr).lte('date', endDateStr)
    ]);

    if (empRes.data) setEmployees(empRes.data);
    if (schedRes.data) setSchedules(schedRes.data);
    
    setLoading(false);
  }

  const generateReport = () => {
    const [year, month] = selectedMonth.split('-');
    const startDate = startOfMonth(new Date(parseInt(year), parseInt(month) - 1));
    const endDate = endOfMonth(startDate);
    const daysInMonth = eachDayOfInterval({ start: startDate, end: endDate });

    return employees.map(emp => {
      const empSchedules = schedules.filter(s => s.employee_id === emp.id);
      
      const totalWorkedMinutes = empSchedules.reduce((sum, s) => sum + (s.worked_minutes || 0), 0);
      const totalOvertimeMinutes = empSchedules.reduce((sum, s) => {
        const dailyOvertime = Math.max(0, (s.worked_minutes || 0) - 480); // 8 hours = 480 mins
        return sum + dailyOvertime;
      }, 0);
      const totalRegularMinutes = totalWorkedMinutes - totalOvertimeMinutes;
      
      const totalBreakMinutes = empSchedules.reduce((sum, s) => sum + (s.break_minutes || 0), 0);
      const daysWorked = empSchedules.filter(s => s.category === 'Work' && s.worked_minutes > 0).length;
      const sickDays = empSchedules.filter(s => s.category === 'Sick' && isApproved(s.note)).length;
      const vacationDays = empSchedules.filter(s => s.category === 'Vacation' && isApproved(s.note)).length;
      
      // Calculate public holidays: either explicitly marked, or automatically detected on weekdays
      let publicHolidays = empSchedules.filter(s => s.category === 'Public Holiday' && isApproved(s.note)).length;
      
      // Auto-detect public holidays that the employee didn't work on (and wasn't on vacation/sick)
      daysInMonth.forEach(day => {
        const dateStr = format(day, 'yyyy-MM-dd');
        const holidayName = getKosovoHoliday(day);
        if (holidayName && !isWeekend(day)) {
          const sched = empSchedules.find(s => s.date === dateStr);
          // If they don't have a schedule, or they have a schedule but it's not already counted as a holiday/sick/vacation
          if (!sched || (sched.category !== 'Public Holiday' && sched.category !== 'Sick' && sched.category !== 'Vacation' && sched.category !== 'Work')) {
            publicHolidays++;
          }
        }
      });

      const offDays = empSchedules.filter(s => s.category === 'Off').length;

      return {
        ...emp,
        empSchedules,
        totalWorkedMinutes,
        totalOvertimeMinutes,
        totalRegularMinutes,
        totalBreakMinutes,
        daysWorked,
        sickDays,
        vacationDays,
        publicHolidays,
        offDays
      };
    });
  };

  const downloadPDF = () => {
    const doc = new jsPDF();
    const [year, month] = selectedMonth.split('-');
    const startDate = startOfMonth(new Date(parseInt(year), parseInt(month) - 1));
    const endDate = endOfMonth(startDate);
    const daysInMonth = eachDayOfInterval({ start: startDate, end: endDate });

    doc.setFontSize(18);
    doc.text(`Monthly Attendance Report - ${format(startDate, 'MMMM yyyy')}`, 14, 22);
    
    let yPos = 30;

    reportData.forEach((emp, index) => {
      if (index > 0) {
        doc.addPage();
        yPos = 20;
      }

      doc.setFontSize(14);
      doc.text(`${emp.first_name} ${emp.last_name} (${emp.employee_number}) - ${emp.department}`, 14, yPos);
      yPos += 6;

      doc.setFontSize(10);
      doc.text(`Total Hours: ${formatMinutes(emp.totalWorkedMinutes)} | Overtime: ${formatMinutes(emp.totalOvertimeMinutes)} | Days Worked: ${emp.daysWorked} | Sick: ${emp.sickDays} | Vacation: ${emp.vacationDays} | Holidays: ${emp.publicHolidays}`, 14, yPos);
      yPos += 6;

      const tableData = daysInMonth.map(day => {
        const dateStr = format(day, 'yyyy-MM-dd');
        const sched = emp.empSchedules.find(s => s.date === dateStr);
        const holidayName = getKosovoHoliday(day);
        
        if (!sched) {
          if (holidayName && !isWeekend(day)) {
            return [format(day, 'MMM dd (EEE)'), `Public Holiday (${holidayName})`, '-', '-', '-', '-', '-'];
          }
          return [format(day, 'MMM dd (EEE)'), '-', '-', '-', '-', '-', '-'];
        }

        const dailyOvertime = Math.max(0, (sched.worked_minutes || 0) - 480);
        const plannedShift = sched.note?.startsWith('PLANNED:') ? sched.note.replace('PLANNED:', '') : null;
        
        let categoryDisplay = sched.category;
        if (holidayName && sched.category !== 'Public Holiday') {
          categoryDisplay = `${sched.category} (Holiday: ${holidayName})`;
        }

        return [
          format(day, 'MMM dd (EEE)'),
          categoryDisplay,
          sched.start_time || (plannedShift ? `Planned: ${plannedShift}` : '-'),
          sched.end_time || '-',
          sched.break_minutes ? `${sched.break_minutes}m` : '-',
          sched.worked_minutes ? formatMinutes(sched.worked_minutes) : '-',
          dailyOvertime > 0 ? formatMinutes(dailyOvertime) : '-'
        ];
      });

      autoTable(doc, {
        startY: yPos,
        head: [['Date', 'Status', 'Clock In', 'Clock Out', 'Break', 'Total Hours', 'Overtime']],
        body: tableData,
        theme: 'grid',
        headStyles: { fillColor: [26, 115, 232] },
        styles: { fontSize: 9 },
        alternateRowStyles: { fillColor: [245, 247, 250] },
      });

      yPos = (doc as any).lastAutoTable.finalY + 15;
    });

    doc.save(`Attendance_Report_${selectedMonth}.pdf`);
    toast.success('PDF report downloaded successfully');
  };

  const reportData = generateReport();

  const downloadCSV = () => {
    const headers = [
      'Employee Name',
      'ID Number',
      'Department',
      'Days Worked',
      'Sick Days',
      'Vacation Days',
      'Public Holidays',
      'Total Break (mins)',
      'Regular Hours',
      'Overtime Hours',
      'Total Hours'
    ];

    const csvData = reportData.map(emp => [
      `${emp.first_name} ${emp.last_name}`,
      emp.employee_number,
      emp.department,
      emp.daysWorked,
      emp.sickDays,
      emp.vacationDays,
      emp.publicHolidays,
      emp.totalBreakMinutes,
      formatMinutes(emp.totalRegularMinutes),
      formatMinutes(emp.totalOvertimeMinutes),
      formatMinutes(emp.totalWorkedMinutes)
    ]);

    const csvContent = [
      headers.join(','),
      ...csvData.map(row => row.map(cell => `"${cell}"`).join(','))
    ].join('\n');

    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    const url = URL.createObjectURL(blob);
    link.setAttribute('href', url);
    link.setAttribute('download', `Attendance_Summary_${selectedMonth}.csv`);
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    toast.success('CSV report downloaded successfully');
  };

  const getCategoryColor = (category: string) => {
    switch (category) {
      case 'Work': return 'text-indigo-600 bg-indigo-50';
      case 'Sick': return 'text-rose-600 bg-rose-50';
      case 'Vacation': return 'text-emerald-600 bg-emerald-50';
      case 'Public Holiday': return 'text-purple-600 bg-purple-50';
      case 'Off': return 'text-slate-600 bg-slate-100';
      default: return 'text-orange-600 bg-orange-50';
    }
  };

  return (
    <div className="space-y-6 max-w-7xl mx-auto pb-12">
      <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div className="flex items-center gap-4">
          <h2 className="text-2xl sm:text-3xl font-normal text-slate-800 tracking-tight">
            Monthly Reports
          </h2>
        </div>
        
        <div className="flex items-center gap-4">
          <input
            type="month"
            value={selectedMonth}
            onChange={(e) => setSelectedMonth(e.target.value)}
            className="px-4 py-2 border border-slate-300 rounded-md shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm font-medium text-slate-700"
          />
          <button
            onClick={downloadCSV}
            disabled={loading || reportData.length === 0}
            className="flex items-center gap-2 bg-emerald-600 text-white px-4 py-2 rounded-md hover:bg-emerald-700 transition-colors font-medium text-sm shadow-sm disabled:opacity-50"
          >
            <FileSpreadsheet className="w-4 h-4" />
            CSV
          </button>
          <button
            onClick={downloadPDF}
            disabled={loading || reportData.length === 0}
            className="flex items-center gap-2 bg-[#1a73e8] text-white px-4 py-2 rounded-md hover:bg-[#1557b0] transition-colors font-medium text-sm shadow-sm disabled:opacity-50"
          >
            <Download className="w-4 h-4" />
            PDF
          </button>
          <button
            onClick={() => window.print()}
            className="flex items-center gap-2 bg-white border border-slate-300 text-slate-700 px-4 py-2 rounded-md hover:bg-slate-50 transition-colors font-medium text-sm shadow-sm"
          >
            <Printer className="w-4 h-4" />
            Print
          </button>
        </div>
      </div>

      <div className="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
        <div className="overflow-x-auto">
          <table className="w-full text-left text-sm">
            <thead className="bg-slate-50 text-slate-600 font-medium border-b border-slate-200 uppercase tracking-wider text-xs">
              <tr>
                <th className="px-6 py-4">Employee</th>
                <th className="px-6 py-4">ID Number</th>
                <th className="px-6 py-4 text-right">Days Worked</th>
                <th className="px-6 py-4 text-right">Sick Days</th>
                <th className="px-6 py-4 text-right">Vacation</th>
                <th className="px-6 py-4 text-right">Holidays</th>
                <th className="px-6 py-4 text-right">Total Break</th>
                <th className="px-6 py-4 text-right">Overtime</th>
                <th className="px-6 py-4 text-right">Total Hours</th>
                <th className="px-6 py-4"></th>
              </tr>
            </thead>
            <tbody className="divide-y divide-slate-100">
              {loading ? (
                <tr>
                  <td colSpan={10} className="px-6 py-8 text-center text-slate-500">Generating report...</td>
                </tr>
              ) : reportData.length === 0 ? (
                <tr>
                  <td colSpan={10} className="px-6 py-8 text-center text-slate-500">No data found for this month</td>
                </tr>
              ) : reportData.map(row => (
                <React.Fragment key={row.id}>
                  <tr 
                    className="hover:bg-slate-50 transition-colors cursor-pointer"
                    onClick={() => setExpandedEmp(expandedEmp === row.id ? null : row.id)}
                  >
                    <td className="px-6 py-4">
                      <div className="font-medium text-slate-900">{row.first_name} {row.last_name}</div>
                      <div className="text-slate-500 text-xs">{row.department}</div>
                    </td>
                    <td className="px-6 py-4 font-mono text-slate-600">
                      {row.employee_number}
                    </td>
                    <td className="px-6 py-4 text-right font-medium text-slate-700">
                      {row.daysWorked}
                    </td>
                    <td className="px-6 py-4 text-right text-rose-600 font-medium">
                      {row.sickDays}
                    </td>
                    <td className="px-6 py-4 text-right text-emerald-600 font-medium">
                      {row.vacationDays}
                    </td>
                    <td className="px-6 py-4 text-right text-purple-600 font-medium">
                      {row.publicHolidays}
                    </td>
                    <td className="px-6 py-4 text-right text-slate-600">
                      {formatMinutes(row.totalBreakMinutes)}
                    </td>
                    <td className="px-6 py-4 text-right font-mono font-medium text-amber-600">
                      {row.totalOvertimeMinutes > 0 ? formatMinutes(row.totalOvertimeMinutes) : '-'}
                    </td>
                    <td className="px-6 py-4 text-right font-mono font-bold text-indigo-700 text-base">
                      {formatMinutes(row.totalWorkedMinutes)}
                    </td>
                    <td className="px-6 py-4 text-right text-slate-400">
                      {expandedEmp === row.id ? <ChevronUp className="w-5 h-5 inline" /> : <ChevronDown className="w-5 h-5 inline" />}
                    </td>
                  </tr>
                  
                  {expandedEmp === row.id && (
                    <tr className="bg-slate-50/50 border-b border-slate-200">
                      <td colSpan={10} className="px-6 py-6">
                        <div className="bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden">
                          <div className="px-4 py-3 bg-slate-50 border-b border-slate-200 font-medium text-slate-700 text-sm">
                            Daily Breakdown - {format(parseISO(`${selectedMonth}-01`), 'MMMM yyyy')}
                          </div>
                          <table className="w-full text-left text-sm">
                            <thead className="bg-white text-slate-500 border-b border-slate-100 text-xs uppercase">
                              <tr>
                                <th className="px-4 py-2">Date</th>
                                <th className="px-4 py-2">Status</th>
                                <th className="px-4 py-2">Clock In</th>
                                <th className="px-4 py-2">Clock Out</th>
                                <th className="px-4 py-2">Break</th>
                                <th className="px-4 py-2">Overtime</th>
                                <th className="px-4 py-2">Total Hours</th>
                              </tr>
                            </thead>
                            <tbody className="divide-y divide-slate-100">
                              {(() => {
                                const [year, month] = selectedMonth.split('-');
                                const startDate = startOfMonth(new Date(parseInt(year), parseInt(month) - 1));
                                const endDate = endOfMonth(startDate);
                                const daysInMonth = eachDayOfInterval({ start: startDate, end: endDate });
                                
                                return daysInMonth.map(day => {
                                  const dateStr = format(day, 'yyyy-MM-dd');
                                  const sched = row.empSchedules.find(s => s.date === dateStr);
                                  const holidayName = getKosovoHoliday(day);
                                  const isWeekendDay = isWeekend(day);
                                  
                                  if (!sched) {
                                    if (holidayName && !isWeekendDay) {
                                      return (
                                        <tr key={dateStr} className="hover:bg-slate-50">
                                          <td className="px-4 py-2 font-medium text-slate-700">{format(day, 'MMM dd (EEE)')}</td>
                                          <td className="px-4 py-2">
                                            <span className="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-50 text-purple-700 ring-1 ring-inset ring-purple-600/20">
                                              Public Holiday ({holidayName})
                                            </span>
                                          </td>
                                          <td className="px-4 py-2 text-slate-400">-</td>
                                          <td className="px-4 py-2 text-slate-400">-</td>
                                          <td className="px-4 py-2 text-slate-400">-</td>
                                          <td className="px-4 py-2 text-slate-400">-</td>
                                          <td className="px-4 py-2 text-slate-400">-</td>
                                        </tr>
                                      );
                                    }
                                    return null; // Only show days with records or holidays in UI to save space
                                  }
                                  
                                  const dailyOvertime = Math.max(0, (sched.worked_minutes || 0) - 480);
                                  
                                  return (
                                    <tr key={dateStr} className="hover:bg-slate-50">
                                      <td className="px-4 py-2 font-medium text-slate-700">
                                        {format(day, 'MMM dd (EEE)')}
                                      </td>
                                      <td className="px-4 py-2">
                                        <div className="flex flex-col gap-1 items-start">
                                          <span className={`inline-flex px-2 py-0.5 rounded text-xs font-medium ${getCategoryColor(sched.category)}`}>
                                            {sched.category}
                                          </span>
                                          {holidayName && sched.category !== 'Public Holiday' && (
                                            <span className="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-50 text-purple-700 ring-1 ring-inset ring-purple-600/20">
                                              {holidayName}
                                            </span>
                                          )}
                                        </div>
                                      </td>
                                      <td className="px-4 py-2 text-slate-600 font-mono text-xs">
                                        {sched.start_time || '-'}
                                      </td>
                                      <td className="px-4 py-2 text-slate-600 font-mono text-xs">
                                        {sched.end_time || '-'}
                                      </td>
                                      <td className="px-4 py-2 text-slate-600">
                                        {sched.break_minutes ? `${sched.break_minutes}m` : '-'}
                                      </td>
                                      <td className="px-4 py-2 font-mono font-medium text-amber-600">
                                        {dailyOvertime > 0 ? formatMinutes(dailyOvertime) : '-'}
                                      </td>
                                      <td className="px-4 py-2 font-mono font-medium text-indigo-600">
                                        {sched.worked_minutes ? formatMinutes(sched.worked_minutes) : '-'}
                                      </td>
                                    </tr>
                                  );
                                });
                              })()}
                            </tbody>
                          </table>
                        </div>
                      </td>
                    </tr>
                  )}
                </React.Fragment>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}
